# ── docker-compose 환경변수 예시 ──────────────────────────────
# 이 파일을 복사해서 .env 로 만들고 값을 채우세요
# cp .env.example .env
#
# ⚠️ .env 파일은 절대 git에 커밋하지 마세요! (.gitignore에 추가됨)

# MySQL root 비밀번호
DB_ROOT_PASSWORD=your_strong_password_here

# JWT 서명 키 (32자 이상, 영문+숫자 조합 권장)
JWT_SECRET=your_jwt_secret_key_must_be_at_least_32_characters_long
